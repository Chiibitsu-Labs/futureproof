# ~ The Mirror ~ environment variables ~
# Copy to .env.local for local dev. In production, set these in the Vercel dashboard.
# Never commit real keys. Everything here is read server-side only.

# Anthropic API key for the diagnosis call (server-side only, never shipped to the client).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional ~ override the model. Defaults to a current, capable Claude model.
MIRROR_MODEL=claude-sonnet-4-6

# Optional capture ~ write opt-ins to YOUR Supabase database (you own the data).
# Server-side only. If unset, capture is skipped gracefully. See docs/supabase-setup.md.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Optional email ~ send people what they ticked, via Resend. See docs/email-setup.md.
# If unset, no email is sent (capture still works). MIRROR_FROM_EMAIL must be a
# verified sender on your Resend domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
MIRROR_FROM_EMAIL=The Mirror <hello@chiibitsu.com>
